// This is your Prisma schema file
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String  @id @default(cuid())
  clerkId String? @unique
  email   String  @unique
  name    String?
  phone   String?
  avatar  String?

  // Profile Information
  bio String?

  // Address Information
  addresses        Address[]
  defaultAddressId String?

  // Account Type & Permissions
  role     UserRole @default(CUSTOMER)
  isActive Boolean  @default(true)

  // Preferences
  newsletter    Boolean @default(false)
  notifications Boolean @default(true)

  // Wishlist, cart & orders
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  orders        Order[]

  // Gift Cards
  purchasedGiftCards GiftCard[]

  // Reviews
  reviews Review[]

  // Audit
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?
}

model Address {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName String
  phone    String
  email    String
  street   String
  city     String
  state    String
  zipCode  String
  country  String

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id String @id @default(cuid())

  name String
  slug String  @unique
  icon String?

  sortOrder Int @default(0)

  products      Product[]
  subcategories Subcategory[]

  megaMenu Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subcategory {
  id String @id @default(cuid())

  name String
  slug String @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model Product {
  id String @id @default(cuid())

  // Basic Info
  name        String
  slug        String  @unique
  description String?

  // Product Identity
  sku   String? @unique
  brand String?
  model String?

  // Pricing
  price    Float
  oldPrice Float?

  // Ratings
  rating Float @default(0)

  // Media
  image  String?
  images String[] @default([])

  // Inventory
  stock         Int @default(0)
  reservedStock Int @default(0)

  // Physical Info
  weight Float?

  // Status
  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)

  // Outlet
  isOutlet       Boolean @default(false)
  outletDiscount Float?
  outletStock    Int?

  // Condition
  condition ProductCondition @default(NEW)

  // Analytics
  viewCount Int @default(0)

  // Categories
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  // Relations
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  reviews       Review[]

  orderItems OrderItem[] // ADD THIS

  specifications ProductSpecification[]
  variants       ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([brand])
  @@index([isFeatured])
  @@index([isActive])
}

model ProductSpecification {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Example:
  // "Performance"
  // "Display"
  // "Battery"
  group String?

  key   String
  value String

  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Example:
  // "16GB / 512GB / Black"
  name String

  sku String? @unique

  price Float?
  stock Int    @default(0)

  image String?

  isActive Boolean @default(true)

  options ProductVariantOption[]

  // ADD THESE
  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ProductVariantOption {
  id String @id @default(cuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // Example:
  // name: "RAM"
  // value: "16GB"
  name  String
  value String

  @@index([variantId])
}

model Review {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  rating  Int
  title   String?
  comment String

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

model CartItem {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity Int @default(1)

  // Optional future support
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, variantId])
}

model Order {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items OrderItem[]

  total Float

  status OrderStatus @default(PENDING)

  paymentMethod PaymentMethod @default(CARD)
  paymentStatus PaymentStatus @default(PENDING)

  // Stripe
  stripePaymentIntentId String?
  stripeSessionId       String?

  // Shipping Snapshot
  shippingAddress Json?

  // Gift Cards
  giftCards            GiftCard[]
  giftCardTransactions GiftCardTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity Int
  price    Float

  createdAt DateTime @default(now())
}

model WishlistItem {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model GiftCard {
  id String @id @default(cuid())

  code        String @unique @default(cuid())
  displayCode String @unique

  // Balance
  initialAmount  Float
  currentBalance Float

  currency String @default("EUR")

  // Status
  status GiftCardStatus @default(ACTIVE)

  expiresAt   DateTime?
  activatedAt DateTime?
  usedAt      DateTime?

  // Purchaser
  purchaserId String?
  purchaser   User?   @relation(fields: [purchaserId], references: [id], onDelete: SetNull)

  purchaserEmail String?
  purchaserName  String?

  // Recipient
  recipientEmail String?
  recipientName  String?
  recipientPhone String?

  // Message
  message String? @db.Text

  // Order
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // Transactions
  transactions GiftCardTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaserId])
  @@index([recipientEmail])
  @@index([displayCode])
  @@index([status])
}

model GiftCardTransaction {
  id String @id @default(cuid())

  giftCardId String
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  type TransactionType

  amount        Float
  balanceBefore Float
  balanceAfter  Float

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  description String?
  adminNote   String?

  createdAt DateTime @default(now())

  @@index([giftCardId])
  @@index([orderId])
}

model StoreSettings {
  id String @id @default(cuid())

  // Basic Info
  storeName        String  @default("TechStore50")
  storeEmail       String?
  storePhone       String?
  storeDescription String? @db.Text

  // Address
  street  String?
  city    String?
  state   String?
  zipCode String?

  // Shipping
  shippingPrice         Float   @default(0)
  freeShippingThreshold Float?
  deliveryTime          String?

  // SEO
  metaTitle       String?
  metaDescription String?

  // Social Links
  facebook  String?
  instagram String?
  tiktok    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  CUSTOMER
  ADMIN
  VENDOR
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CARD
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ProductCondition {
  NEW
  OPEN_BOX
  REFURBISHED
}

enum GiftCardStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
  TRANSFERRED
}

enum TransactionType {
  ACTIVATION
  PURCHASE
  REDEMPTION
  REFUND
  ADJUSTMENT
  EXPIRY
  TRANSFER
}
